<?xml version="1.0" encoding="utf-8"?>
<!-- item_notification.xml -->
<!-- Đầy đủ tất cả id mà NotificationActivity.addNotifCard() cần:
     tvTitle, tvDescription, tvTime, unreadDot, unreadBar, ivIcon, iconContainer -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="#FFFFFF">

    <!-- unreadBar: thanh xanh bên trái khi chưa đọc -->
    <View
        android:id="@+id/unreadBar"
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:background="#1565C0"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:gravity="center_vertical">

        <!-- Icon container -->
        <FrameLayout
            android:id="@+id/iconContainer"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_transport_icon_teal">

            <ImageView
                android:id="@+id/ivIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_bell"
                android:contentDescription="Notification icon" />
        </FrameLayout>

        <!-- Text content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="8dp">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#1A1A2E"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="Tiêu đề thông báo" />

            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:textColor="#666666"
                android:textSize="13sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:lineSpacingMultiplier="1.3"
                android:text="Nội dung thông báo chi tiết hiển thị ở đây" />

            <TextView
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="#AAAAAA"
                android:textSize="11sp"
                android:text="Vừa xong" />

        </LinearLayout>

        <!-- unreadDot: chấm tròn góc phải khi chưa đọc -->
        <View
            android:id="@+id/unreadDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_unread_dot"
            android:visibility="gone" />

    </LinearLayout>

</androidx.cardview.widget.CardView>