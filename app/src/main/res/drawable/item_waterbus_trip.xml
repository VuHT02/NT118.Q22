<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="8dp"
    android:layout_marginBottom="14dp"
    android:background="@drawable/bg_trip_card"
    android:foreground="?attr/selectableItemBackground"
    android:clipToOutline="true"
    android:padding="16dp">

    <!-- Row 1: Loại ghế + số chỗ trống -->
    <TextView
        android:id="@+id/tvSeatType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ghế ngồi 75 chỗ"
        android:textColor="#8A9BB0"
        android:textSize="13sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="HardcodedText" />

    <TextView
        android:id="@+id/tvAvailableSeats"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Còn 47 chỗ trống"
        android:textColor="#4D9FFF"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="HardcodedText" />

    <!-- Divider -->
    <View
        android:id="@+id/divider1"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="10dp"
        android:background="#1E2D3D"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSeatType" />

    <!-- Row 2: Giờ đi ──●── thời lượng ──●── Giờ đến -->
    <TextView
        android:id="@+id/tvDepartTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="11:00"
        android:textColor="#4D9FFF"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/divider1"
        tools:ignore="HardcodedText" />

    <!-- Dot trái -->
    <ImageView
        android:id="@+id/dotLeft"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/ic_dot_orange"
        android:contentDescription=""
        app:layout_constraintBottom_toBottomOf="@id/tvDepartTime"
        app:layout_constraintStart_toEndOf="@id/tvDepartTime"
        app:layout_constraintTop_toTopOf="@id/tvDepartTime" />

    <!-- Đường nối trái -->
    <View
        android:id="@+id/lineLeft"
        android:layout_width="0dp"
        android:layout_height="2dp"
        android:background="#F5A623"
        app:layout_constraintBottom_toBottomOf="@id/dotLeft"
        app:layout_constraintEnd_toStartOf="@id/tvDuration"
        app:layout_constraintStart_toEndOf="@id/dotLeft"
        app:layout_constraintTop_toTopOf="@id/dotLeft" />

    <!-- Thời lượng hành trình -->
    <TextView
        android:id="@+id/tvDuration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="2dp"
        android:text="0h27"
        android:textColor="#F5A623"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/dotLeft"
        app:layout_constraintEnd_toStartOf="@id/lineRight"
        app:layout_constraintStart_toEndOf="@id/lineLeft"
        tools:ignore="HardcodedText" />

    <!-- Đường nối phải -->
    <View
        android:id="@+id/lineRight"
        android:layout_width="0dp"
        android:layout_height="2dp"
        android:background="#F5A623"
        app:layout_constraintBottom_toBottomOf="@id/dotLeft"
        app:layout_constraintEnd_toStartOf="@id/dotRight"
        app:layout_constraintStart_toEndOf="@id/tvDuration"
        app:layout_constraintTop_toTopOf="@id/dotLeft" />

    <!-- Dot phải -->
    <ImageView
        android:id="@+id/dotRight"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/ic_dot_orange"
        android:contentDescription=""
        app:layout_constraintBottom_toBottomOf="@id/tvDepartTime"
        app:layout_constraintEnd_toStartOf="@id/tvArriveTime"
        app:layout_constraintTop_toTopOf="@id/tvDepartTime" />

    <!-- Giờ đến -->
    <TextView
        android:id="@+id/tvArriveTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="11:27"
        android:textColor="#4D9FFF"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvDepartTime"
        tools:ignore="HardcodedText" />

    <!-- Row 3: Tên bến đi + Tên bến đến -->
    <TextView
        android:id="@+id/tvOrigin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Bến tàu Bạch Đằng"
        android:textColor="#546E7A"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvDepartTime"
        tools:ignore="HardcodedText" />

    <TextView
        android:id="@+id/tvDestination"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Bến tàu Thảo Điền"
        android:textColor="#546E7A"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvArriveTime"
        tools:ignore="HardcodedText" />

    <!-- Divider nét đứt -->
    <View
        android:id="@+id/divider2"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_divider_dashed"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvOrigin" />

    <!-- Row 4: Giá vé + Nút đặt vé -->
    <TextView
        android:id="@+id/tvPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="15.000đ"
        android:textColor="#ECEFF1"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/divider2"
        tools:ignore="HardcodedText" />

    <Button
        android:id="@+id/btnBook"
        android:layout_width="wrap_content"
        android:layout_height="34dp"
        android:layout_marginTop="8dp"
        style="@style/Widget.TransGo.Button.Orange"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="Đặt vé"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvPrice" />

    <!-- Bottom constraint anchor -->
    <Space
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvPrice" />

</androidx.constraintlayout.widget.ConstraintLayout>
