<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/item_notification.xml -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:id="@+id/rootLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="top"
        android:padding="14dp">

        <!-- Unread indicator bar (left border effect) -->
        <View
            android:id="@+id/unreadBar"
            android:layout_width="3dp"
            android:layout_height="match_parent"
            android:background="#F97316"
            android:layout_marginEnd="11dp"
            android:visibility="gone"/>

        <!-- Icon circle -->
        <FrameLayout
            android:id="@+id/iconContainer"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_transport_icon_orange"
            android:layout_marginEnd="12dp">
            <ImageView
                android:id="@+id/ivIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_bell"/>
        </FrameLayout>

        <!-- Text content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#0b1928"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="3dp"/>

            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#6b7a8d"
                android:textSize="12sp"
                android:lineSpacingMultiplier="1.3"
                android:layout_marginBottom="5dp"/>

            <TextView
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#aab0ba"
                android:textSize="10sp"/>
        </LinearLayout>

        <!-- Unread dot -->
        <View
            android:id="@+id/unreadDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_notification_dot"
            android:layout_marginTop="4dp"
            android:layout_marginStart="8dp"
            android:visibility="gone"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
