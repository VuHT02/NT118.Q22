<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="80dp"
        android:clipToPadding="false"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== HEADER ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#0b1928"
                android:padding="16dp"
                android:paddingBottom="20dp">

                <!-- Avatar + Info -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <FrameLayout
                        android:id="@+id/btnEditAvatar"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/bg_avatar_circle_large"
                        android:layout_marginEnd="14dp">
                        <TextView
                            android:id="@+id/tvAvatarInitials"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:textStyle="bold"/>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvUserName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textSize="17sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvUserEmail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#80FFFFFF"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp"/>

                        <!-- Rank pill -->
                        <LinearLayout
                            android:id="@+id/layoutRank"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/bg_rank_pill"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp"
                            android:layout_marginTop="6dp">
                            <ImageView
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:src="@drawable/ic_star"
                                android:layout_marginEnd="4dp"/>
                            <TextView
                                android:id="@+id/tvRank"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#F97316"
                                android:textSize="11sp"
                                android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Points progress card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_points_card"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Điểm thưởng TransGo"
                            android:textColor="#80FFFFFF"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvPointsProgress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#F97316"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progressPoints"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:max="100"
                        android:progressDrawable="@drawable/bg_timer_progress" />

                    <TextView
                        android:id="@+id/tvPointsHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:textColor="#4DFFFFFF"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ===== CONTENT ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <!-- Section: Tài khoản -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TÀI KHOẢN"
                    android:textColor="#9aa5b4"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="8dp"/>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Thông tin cá nhân -->
                        <LinearLayout
                            android:id="@+id/menuPersonalInfo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="14dp"
                            android:background="@drawable/bg_route_item_divider">
                            <FrameLayout
                                android:layout_width="34dp"
                                android:layout_height="34dp"
                                android:background="@drawable/bg_transport_icon_orange"
                                android:layout_marginEnd="12dp">
                                <ImageView android:layout_width="16dp" android:layout_height="16dp"
                                    android:layout_gravity="center" android:src="@drawable/ic_user"/>
                            </FrameLayout>
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Thông tin cá nhân" android:textColor="#0b1928"
                                    android:textSize="13sp" android:textStyle="bold"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Tên, email, số điện thoại" android:textColor="#9aa5b4"
                                    android:textSize="11sp" android:layout_marginTop="1dp"/>
                            </LinearLayout>
                            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                                android:src="@drawable/ic_chevron_right"/>
                        </LinearLayout>

                        <!-- Đổi mật khẩu -->
                        <LinearLayout
                            android:id="@+id/menuChangePassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="14dp">
                            <FrameLayout
                                android:layout_width="34dp"
                                android:layout_height="34dp"
                                android:background="@drawable/bg_transport_icon_blue"
                                android:layout_marginEnd="12dp">
                                <ImageView android:layout_width="16dp" android:layout_height="16dp"
                                    android:layout_gravity="center" android:src="@drawable/ic_lock"/>
                            </FrameLayout>
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Đổi mật khẩu" android:textColor="#0b1928"
                                    android:textSize="13sp" android:textStyle="bold"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Cập nhật mật khẩu mới" android:textColor="#9aa5b4"
                                    android:textSize="11sp" android:layout_marginTop="1dp"/>
                            </LinearLayout>
                            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                                android:src="@drawable/ic_chevron_right"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Section: Hoạt động -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HOẠT ĐỘNG"
                    android:textColor="#9aa5b4"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="8dp"/>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Lịch sử giao dịch -->
                        <LinearLayout
                            android:id="@+id/menuHistory"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="14dp"
                            android:background="@drawable/bg_route_item_divider">
                            <FrameLayout
                                android:layout_width="34dp"
                                android:layout_height="34dp"
                                android:background="@drawable/bg_stat_green"
                                android:layout_marginEnd="12dp">
                                <ImageView android:layout_width="16dp" android:layout_height="16dp"
                                    android:layout_gravity="center" android:src="@drawable/ic_history"/>
                            </FrameLayout>
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Lịch sử giao dịch" android:textColor="#0b1928"
                                    android:textSize="13sp" android:textStyle="bold"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Xem tất cả chuyến đi &amp; thanh toán" android:textColor="#9aa5b4"
                                    android:textSize="11sp" android:layout_marginTop="1dp"/>
                            </LinearLayout>
                            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                                android:src="@drawable/ic_chevron_right"/>
                        </LinearLayout>

                        <!-- Điểm thưởng -->
                        <LinearLayout
                            android:id="@+id/menuRewards"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="14dp">
                            <FrameLayout
                                android:layout_width="34dp"
                                android:layout_height="34dp"
                                android:background="@drawable/bg_transport_icon_orange"
                                android:layout_marginEnd="12dp">
                                <ImageView android:layout_width="16dp" android:layout_height="16dp"
                                    android:layout_gravity="center" android:src="@drawable/ic_star"/>
                            </FrameLayout>
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Điểm thưởng" android:textColor="#0b1928"
                                    android:textSize="13sp" android:textStyle="bold"/>
                                <TextView
                                    android:id="@+id/tvPointsSub"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:textColor="#9aa5b4"
                                    android:textSize="11sp" android:layout_marginTop="1dp"/>
                            </LinearLayout>
                            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                                android:src="@drawable/ic_chevron_right"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Đăng xuất -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout
                        android:id="@+id/menuLogout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="14dp">
                        <FrameLayout
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/bg_logout_icon"
                            android:layout_marginEnd="12dp">
                            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                                android:layout_gravity="center" android:src="@drawable/ic_logout"/>
                        </FrameLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đăng xuất"
                            android:textColor="#FF5252"
                            android:textSize="13sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Nav -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        android:elevation="12dp"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/bottom_nav_color"
        app:itemTextColor="@color/bottom_nav_color"
        app:labelVisibilityMode="labeled"
        app:itemActiveIndicatorStyle="@style/Widget.TransGo.BottomNav.ActiveIndicator"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>