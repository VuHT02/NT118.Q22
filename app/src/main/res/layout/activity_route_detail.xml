<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/routeDetailRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8">

    <FrameLayout
        android:id="@+id/mapContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#DDE6EF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/panelSplitGuide">

        <TextView
            android:id="@+id/tvMapFallback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:text="@string/route_map_fallback_hint"
            android:textAlignment="center"
            android:textColor="#4A5565"
            android:textSize="14sp"
            android:visibility="gone"
            tools:visibility="visible"/>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:elevation="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_header_icon_btn">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_arrow_back"
                android:contentDescription="@string/route_map_back"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/route_map_title"
                android:textColor="#0b1928"
                android:textSize="20sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tvRouteMetaTop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#5F6B7A"
                android:textSize="12sp"
                tools:text="Bến Thành → Suối Tiên"/>
        </LinearLayout>
    </LinearLayout>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/panelSplitGuide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.62"/>

    <androidx.cardview.widget.CardView
        android:id="@+id/routeInfoCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="10dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toTopOf="@id/panelSplitGuide"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Drag handle -->
            <LinearLayout
                android:id="@+id/panelHandleTapArea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:contentDescription="@string/route_panel_collapse"
                android:focusable="true"
                android:gravity="center"
                android:paddingTop="2dp"
                android:paddingBottom="10dp">
                <View
                    android:layout_width="52dp"
                    android:layout_height="5dp"
                    android:background="@drawable/bg_panel_handle"/>
            </LinearLayout>

            <!-- Route header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvRouteCode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#F97316"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        tools:text="Tuyến 01"/>
                    <TextView
                        android:id="@+id/tvRouteTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="#0b1928"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:ellipsize="end"
                        android:maxLines="1"
                        tools:text="Bến Thành → Suối Tiên"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvRouteBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_btn_orange"
                    android:backgroundTint="@null"
                    android:paddingStart="12dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="6dp"
                    android:text="Đang hiển thị"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/routeInfoExpandableSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvRouteSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textColor="#5F6B7A"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.4"
                    tools:text="Tuyến buýt đi qua các điểm chính và hiển thị lộ trình trực quan trên bản đồ."/>

                <!-- Stats row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_stat_card"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:layout_marginEnd="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thời gian"
                            android:textColor="#9aa5b4"
                            android:textSize="10sp"/>
                        <TextView
                            android:id="@+id/tvRouteDuration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="#0b1928"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            tools:text="23 phút"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_stat_green"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Giá vé"
                            android:textColor="#2E7D32"
                            android:textSize="10sp"/>
                        <TextView
                            android:id="@+id/tvRouteFare"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="#2E7D32"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            tools:text="10.000đ"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Stops -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/route_map_stops_title"
                    android:textColor="#0b1928"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

                <LinearLayout
                    android:id="@+id/stopListContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_stat_card"
                    android:orientation="vertical"
                    android:padding="10dp"
                    tools:ignore="UselessParent"/>

                <!-- ✅ Action buttons — Đặt vé + Mở Maps + Đóng -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <!-- ✅ Nút Đặt vé — nổi bật nhất -->
                    <TextView
                        android:id="@+id/btnBookTicket"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_btn_orange"
                        android:backgroundTint="@null"
                        android:gravity="center"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:text="🎫 Đặt vé"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <!-- Mở Google Maps -->
                    <TextView
                        android:id="@+id/btnOpenMaps"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_button_rounded"
                        android:backgroundTint="@null"
                        android:gravity="center"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:text="@string/route_map_open_external"
                        android:textColor="#0b1928"
                        android:textSize="12sp"
                        android:textStyle="bold"/>

                    <!-- Đóng -->
                    <TextView
                        android:id="@+id/btnCloseRoute"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_button_rounded"
                        android:backgroundTint="@null"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingTop="12dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="12dp"
                        android:text="@string/route_map_back"
                        android:textColor="#9aa5b4"
                        android:textSize="12sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>