<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="80dp"
        android:clipToPadding="false"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== HERO HEADER ===== -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="185dp"
                android:background="#0b1928">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/bg_grid"
                    android:scaleType="fitXY"
                    android:alpha="0.35"/>

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:layout_gravity="bottom"
                    android:src="@drawable/img_city_skyline"
                    android:scaleType="fitXY"
                    android:alpha="0.5"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <FrameLayout
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/bg_logo_circle"
                            android:layout_marginEnd="8dp">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_transgo_logo"/>
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="TRANS"
                                    android:textColor="#FFFFFF"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:fontFamily="sans-serif-condensed"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="GO"
                                    android:textColor="#F97316"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:fontFamily="sans-serif-condensed"/>
                            </LinearLayout>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="DI CHUYỂN THÔNG MINH"
                                android:textColor="#40FFFFFF"
                                android:textSize="7sp"
                                android:letterSpacing="0.12"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/btnLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/bg_button_rounded"
                            android:backgroundTint="#2D3748"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:layout_marginEnd="8dp">
                            <ImageView
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:src="@drawable/ic_location_on"
                                app:tint="#FFFFFF"
                                android:layout_marginEnd="4dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="HCM"
                                android:textColor="#FFFFFF"
                                android:textSize="10sp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <FrameLayout
                            android:id="@+id/btnNotification"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:layout_marginEnd="8dp">
                            <FrameLayout
                                android:layout_width="34dp"
                                android:layout_height="34dp"
                                android:background="@drawable/bg_header_icon_btn">
                                <ImageView
                                    android:layout_width="17dp"
                                    android:layout_height="17dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_bell"
                                    app:tint="#FFFFFF"/>
                            </FrameLayout>
                            <View
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:background="@drawable/bg_badge_orange"
                                android:layout_gravity="top|end"
                                android:layout_marginTop="2dp"
                                android:layout_marginEnd="2dp"/>
                        </FrameLayout>

                        <FrameLayout
                            android:id="@+id/btnProfile"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/bg_avatar_circle_large">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_user"
                                app:tint="#FFFFFF"/>
                        </FrameLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_greeting_card"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginEnd="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Xin chào,"
                                android:textColor="#80FFFFFF"
                                android:textSize="10sp"/>
                            <TextView
                                android:id="@+id/tvUserName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Người dùng"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:layout_marginTop="1dp"/>
                        </LinearLayout>
                        <View
                            android:layout_width="1dp"
                            android:layout_height="24dp"
                            android:background="#30FFFFFF"
                            android:layout_marginEnd="12dp"/>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tvTodayDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="20/04/2026"
                                android:textColor="#80FFFFFF"
                                android:textSize="9sp"/>
                            <TextView
                                android:id="@+id/tvTripCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 chuyến hôm nay"
                                android:textColor="#F97316"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:layout_marginTop="1dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

            <!-- ===== SEARCH CARD (Giữ đúng Layout ban đầu) ===== -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:layout_marginTop="-24dp"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="10dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <!-- Hàng 1: Input + Nút ĐI NGAY -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_input_field"
                        android:paddingStart="14dp"
                        android:paddingEnd="6dp"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_search"
                            app:tint="#64748B"
                            android:layout_marginEnd="10dp"/>

                        <EditText
                            android:id="@+id/etDestinationInput"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@android:color/transparent"
                            android:hint="Nhập điểm bạn muốn đến..."
                            android:inputType="text"
                            android:textColor="#0b1928"
                            android:textColorHint="#9AA5B4"
                            android:textSize="14sp"/>

                        <TextView
                            android:id="@+id/btnGoNow"
                            android:layout_width="wrap_content"
                            android:layout_height="38dp"
                            android:gravity="center"
                            android:text="ĐI NGAY"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_button_rounded"
                            android:backgroundTint="#F97316"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"/>
                    </LinearLayout>

                    <!-- Hàng 2: Nút LỘ TRÌNH + Chips -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/btnRoutePlanner"
                            android:layout_width="wrap_content"
                            android:layout_height="34dp"
                            android:gravity="center"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:text="LỘ TRÌNH"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_button_rounded"
                            android:backgroundTint="#F97316"
                            android:layout_marginEnd="12dp"/>

                        <HorizontalScrollView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:scrollbars="none">
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">
                                <TextView
                                    android:id="@+id/chipDestinationBenThanh"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="📍 Bến Thành"
                                    android:textColor="#E65100"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:background="@drawable/bg_badge_orange"
                                    android:paddingStart="12dp"
                                    android:paddingEnd="12dp"
                                    android:paddingTop="6dp"
                                    android:paddingBottom="6dp"
                                    android:layout_marginEnd="8dp"/>
                                <TextView
                                    android:id="@+id/chipDestinationSuoiTien"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🏫 Suối Tiên"
                                    android:textColor="#64748B"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:background="@drawable/bg_button_rounded"
                                    android:backgroundTint="#F1F5F9"
                                    android:paddingStart="12dp"
                                    android:paddingEnd="12dp"
                                    android:paddingTop="6dp"
                                    android:paddingBottom="6dp"/>
                            </LinearLayout>
                        </HorizontalScrollView>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== CHỌN PHƯƠNG TIỆN (Khớp ảnh) ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chọn phương tiện"
                    android:textColor="#0b1928"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3"
                    android:layout_marginBottom="24dp">

                    <!-- Xe buýt -->
                    <LinearLayout
                        android:id="@+id/btnTransportBus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <FrameLayout
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:background="@drawable/bg_icon_gray">
                            <ImageView
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_bus"
                                app:tint="#64748B"/>
                        </FrameLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Xe buýt"
                            android:textSize="12sp"
                            android:textColor="#64748B"
                            android:textStyle="bold"
                            android:layout_marginTop="8dp"/>
                    </LinearLayout>

                    <!-- Metro -->
                    <LinearLayout
                        android:id="@+id/btnTransportMetro"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <FrameLayout
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:background="@drawable/bg_icon_gray">
                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_metro"
                                app:tint="#64748B"/>
                        </FrameLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Metro"
                            android:textSize="12sp"
                            android:textColor="#64748B"
                            android:textStyle="bold"
                            android:layout_marginTop="8dp"/>
                    </LinearLayout>

                    <!-- Waterbus (Selected) -->
                    <LinearLayout
                        android:id="@+id/btnTransportWaterbus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <FrameLayout
                            android:layout_width="80dp"
                            android:layout_height="64dp"
                            android:background="@drawable/bg_icon_blue">
                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_waterbus"
                                app:tint="#FFFFFF"/>
                        </FrameLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Cards stats -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_balance_card"
                            android:orientation="vertical"
                            android:padding="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Số dư"
                                android:textColor="#80FFFFFF"
                                android:textSize="10sp" />
                            <TextView
                                android:id="@+id/tvBalance"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#F97316"
                                android:textSize="20sp"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/btnTopUp"
                                style="@style/Widget.TransGo.Button.Orange"
                                android:layout_width="wrap_content"
                                android:layout_height="30dp"
                                android:backgroundTint="@null"
                                android:gravity="center"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:text="Nạp thêm"
                                android:textColor="#FFFFFF"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:layout_marginTop="10dp"/>
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:background="@drawable/bg_stat_card"
                                android:padding="10dp"
                                android:layout_marginBottom="6dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Tổng chi tháng này" android:textColor="#9aa5b4" android:textSize="10sp"/>
                                <TextView android:id="@+id/tvMonthlySpend" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:textColor="#0b1928" android:textSize="15sp" android:textStyle="bold"/>
                            </LinearLayout>
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:background="@drawable/bg_icon_circle_teal"
                                android:backgroundTint="#E0F2F1"
                                android:padding="10dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="CO₂ tiết kiệm" android:textColor="#2E7D32" android:textSize="10sp"/>
                                <TextView android:id="@+id/tvCO2Saved" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:textColor="#2E7D32" android:textSize="15sp" android:textStyle="bold"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        android:elevation="12dp"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/bottom_nav_color"
        app:itemTextColor="@color/bottom_nav_color"
        app:itemIconSize="22dp"
        app:labelVisibilityMode="labeled"
        app:itemPaddingTop="8dp"
        app:itemPaddingBottom="6dp"
        app:itemActiveIndicatorStyle="@style/Widget.TransGo.BottomNav.ActiveIndicator"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>