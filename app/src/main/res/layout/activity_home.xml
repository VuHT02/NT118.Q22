<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="80dp"
        android:clipToPadding="false"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== HERO HEADER ===== -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="185dp"
                android:background="#0b1928">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/bg_grid"
                    android:scaleType="fitXY"
                    android:alpha="0.35"/>

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:layout_gravity="bottom"
                    android:src="@drawable/img_city_skyline"
                    android:scaleType="fitXY"
                    android:alpha="0.5"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <!-- Top bar: logo + actions -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <FrameLayout
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/bg_logo_circle_orange"
                            android:layout_marginEnd="8dp">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_transgo_logo"/>
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="TRANS"
                                    android:textColor="#FFFFFF"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:fontFamily="sans-serif-condensed"
                                    android:includeFontPadding="false"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="GO"
                                    android:textColor="#F97316"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:fontFamily="sans-serif-condensed"
                                    android:includeFontPadding="false"/>
                            </LinearLayout>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="DI CHUYỂN THÔNG MINH"
                                android:textColor="#40FFFFFF"
                                android:textSize="7sp"
                                android:letterSpacing="0.12"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/btnLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/bg_location_pill"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:layout_marginEnd="8dp">
                            <ImageView
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:src="@drawable/ic_location_on"
                                app:tint="#FFFFFF"
                                android:layout_marginEnd="3dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="HCM"
                                android:textColor="#FFFFFF"
                                android:textSize="10sp"
                                android:textStyle="bold"/>
                            <ImageView
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:src="@drawable/ic_chevron_down"
                                app:tint="#FFFFFF"
                                android:layout_marginStart="3dp"/>
                        </LinearLayout>

                        <FrameLayout
                            android:id="@+id/btnNotification"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:layout_marginEnd="8dp">
                            <FrameLayout
                                android:layout_width="34dp"
                                android:layout_height="34dp"
                                android:background="@drawable/bg_header_icon_btn">
                                <ImageView
                                    android:layout_width="17dp"
                                    android:layout_height="17dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_bell"
                                    app:tint="#FFFFFF"/>
                            </FrameLayout>
                            <View
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:background="@drawable/bg_notification_dot"
                                android:layout_gravity="top|end"
                                android:layout_marginTop="2dp"
                                android:layout_marginEnd="2dp"/>
                        </FrameLayout>

                        <FrameLayout
                            android:id="@+id/btnProfile"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/bg_avatar_circle_large">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_user"
                                app:tint="#FFFFFF"/>
                        </FrameLayout>
                    </LinearLayout>

                    <!-- Greeting + today trips -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_greeting_card"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">

                        <!-- Cột 1: Tên người dùng -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginEnd="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Xin chào,"
                                android:textColor="#80FFFFFF"
                                android:textSize="10sp"/>

                            <TextView
                                android:id="@+id/tvUserName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Người dùng"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:layout_marginTop="1dp"/>
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="24dp"
                            android:background="#30FFFFFF"
                            android:layout_marginEnd="12dp"/>

                        <!-- Cột 2: Ngày + số chuyến -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvTodayDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="20/04/2026"
                                android:textColor="#80FFFFFF"
                                android:textSize="9sp"/>

                            <TextView
                                android:id="@+id/tvTripCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 chuyến hôm nay"
                                android:textColor="#F97316"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:layout_marginTop="1dp"/>
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

            <!-- ===== SEARCH CARD (overlap header) ===== -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:layout_marginTop="-18dp"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="12dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <!-- Input row -->
                    <LinearLayout
                        android:id="@+id/searchBar"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_input_field"
                        android:paddingStart="14dp"
                        android:paddingEnd="8dp"
                        android:layout_marginBottom="10dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_search"
                            app:tint="#0b1928"
                            android:layout_marginEnd="10dp"/>

                        <EditText
                            android:id="@+id/etDestinationInput"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@android:color/transparent"
                            android:hint="Nhập điểm bạn muốn đến..."
                            android:imeOptions="actionSearch"
                            android:inputType="textCapWords"
                            android:maxLines="1"
                            android:textColor="#0b1928"
                            android:textColorHint="#BBBBBB"
                            android:textSize="13sp"/>

                        <TextView
                            android:id="@+id/btnGoNow"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:text="Đi ngay"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            style="@style/Widget.TransGo.Button.Orange"
                            android:backgroundTint="@null"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"/>
                    </LinearLayout>

                    <!-- Quick chips row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/btnRoutePlanner"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            style="@style/Widget.TransGo.Button.Orange"
                            android:backgroundTint="@null"
                            android:gravity="center"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:text="Lộ trình"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:layout_marginEnd="10dp"/>

                        <HorizontalScrollView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:scrollbars="none">
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">
                                <TextView
                                    android:id="@+id/chipDestinationBenThanh"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="📍 Bến Thành"
                                    android:textColor="#E65100"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:background="@drawable/bg_quick_route_active"
                                    android:paddingStart="10dp"
                                    android:paddingEnd="10dp"
                                    android:paddingTop="5dp"
                                    android:paddingBottom="5dp"
                                    android:layout_marginEnd="6dp"/>
                                <TextView
                                    android:id="@+id/chipDestinationSuoiTien"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🏫 Suối Tiên"
                                    android:textColor="#4a6080"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:background="@drawable/bg_quick_route"
                                    android:paddingStart="10dp"
                                    android:paddingEnd="10dp"
                                    android:paddingTop="5dp"
                                    android:paddingBottom="5dp"
                                    android:layout_marginEnd="6dp"/>
                                <TextView
                                    android:id="@+id/chipDestinationTanSonNhat"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="✈️ Tân Sơn Nhất"
                                    android:textColor="#4a6080"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:background="@drawable/bg_quick_route"
                                    android:paddingStart="10dp"
                                    android:paddingEnd="10dp"
                                    android:paddingTop="5dp"
                                    android:paddingBottom="5dp"/>
                            </LinearLayout>
                        </HorizontalScrollView>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== MAIN CONTENT ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">

                <!-- ═══════════════════════════════════════ -->
                <!-- 1. CHỌN PHƯƠNG TIỆN                    -->
                <!-- ═══════════════════════════════════════ -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chọn phương tiện"
                    android:textColor="#0b1928"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3"
                    android:layout_marginBottom="20dp">
                    <!-- Xe buýt -->
                    <LinearLayout
                        android:id="@+id/btnTransportBus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp"
                        android:background="@drawable/bg_transport_unselected"
                        android:layout_marginEnd="6dp">
                        <FrameLayout
                            android:id="@+id/ivTransportIconBus"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_icon_gray">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_bus"
                                app:tint="#64748B"/>
                        </FrameLayout>
                        <TextView
                            android:id="@+id/tvTransportLabelBus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Xe buýt"
                            android:textSize="12sp"
                            android:textColor="#64748B"
                            android:layout_marginTop="8dp"/>
                    </LinearLayout>

                    <!-- Metro -->
                    <LinearLayout
                        android:id="@+id/btnTransportMetro"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp"
                        android:background="@drawable/bg_transport_unselected"
                        android:layout_marginEnd="6dp">
                        <FrameLayout
                            android:id="@+id/ivTransportIconMetro"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_icon_gray">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_metro"
                                app:tint="#64748B"/>
                        </FrameLayout>
                        <TextView
                            android:id="@+id/tvTransportLabelMetro"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Metro"
                            android:textSize="12sp"
                            android:textColor="#64748B"
                            android:layout_marginTop="8dp"/>
                    </LinearLayout>

                    <!-- Waterbus -->
                    <LinearLayout
                        android:id="@+id/btnTransportWaterbus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp"
                        android:background="@drawable/bg_transport_selected">
                        <FrameLayout
                            android:id="@+id/ivTransportIconWaterbus"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_icon_blue">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_waterbus"
                                app:tint="#FFFFFF"/>
                        </FrameLayout>
                        <TextView
                            android:id="@+id/tvTransportLabelWaterbus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Waterbus"
                            android:textSize="12sp"
                            android:textColor="#2563EB"
                            android:textStyle="bold"
                            android:layout_marginTop="8dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- ═══════════════════════════════════════ -->
                <!-- 2. THẺ TRANSPASS                       -->
                <!-- ═══════════════════════════════════════ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Thẻ TransPass của bạn"
                        android:textColor="#0b1928"
                        android:textSize="15sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tvCardDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chi tiết →"
                        android:textColor="#F97316"
                        android:textSize="11sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_balance_card"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="3dp"
                                android:text="Số dư"
                                android:textColor="#80FFFFFF"
                                android:textSize="10sp" />

                            <TextView
                                android:id="@+id/tvBalance"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-condensed"
                                android:textColor="#F97316"
                                android:textSize="20sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvBalanceEstimate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="10dp"
                                android:textColor="#40FFFFFF"
                                android:textSize="10sp" />

                            <TextView
                                android:id="@+id/btnTopUp"
                                style="@style/Widget.TransGo.Button.Orange"
                                android:layout_width="wrap_content"
                                android:layout_height="30dp"
                                android:backgroundTint="@null"
                                android:gravity="center"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:text="Nạp thêm"
                                android:textColor="#FFFFFF"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:background="@drawable/bg_stat_card"
                                android:padding="10dp"
                                android:layout_marginBottom="6dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Tổng chi tháng này" android:textColor="#9aa5b4" android:textSize="10sp" android:layout_marginBottom="2dp"/>
                                <TextView android:id="@+id/tvMonthlySpend" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:textColor="#0b1928" android:textSize="15sp" android:textStyle="bold"/>
                            </LinearLayout>
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:background="@drawable/bg_stat_green"
                                android:padding="10dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="CO₂ tiết kiệm" android:textColor="#2E7D32" android:textSize="10sp" android:layout_marginBottom="2dp"/>
                                <TextView android:id="@+id/tvCO2Saved" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:textColor="#2E7D32" android:textSize="15sp" android:textStyle="bold"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ═══════════════════════════════════════ -->
                <!-- 3. TUYẾN HAY ĐI + TAB                  -->
                <!-- ═══════════════════════════════════════ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Tuyến hay đi của bạn"
                        android:textColor="#0b1928"
                        android:textSize="15sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tvSeeAllRoutes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Xem tất cả →"
                        android:textColor="#F97316"
                        android:textSize="11sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Tab: Buýt | Metro | Waterbus -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_tab_container"
                    android:padding="4dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/tabBus"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="\nXe buýt"
                        android:textAlignment="center"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_tab_selected"/>

                    <TextView
                        android:id="@+id/tabMetro"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="\nMetro"
                        android:textAlignment="center"
                        android:textColor="#6B7280"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_tab_unselected"/>

                    <TextView
                        android:id="@+id/tabWaterbus"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="\nWaterbus"
                        android:textAlignment="center"
                        android:textColor="#6B7280"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_tab_unselected"/>

                </LinearLayout>

                <!-- ═══════════════════════════════════════ -->
                <!-- 4. AI GỢI Ý                            -->
                <!-- ═══════════════════════════════════════ -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#0b1928">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">
                            <View
                                android:layout_width="7dp"
                                android:layout_height="7dp"
                                android:background="@drawable/bg_ai_dot"
                                android:layout_marginEnd="6dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="AI GỢI Ý"
                                android:textColor="#2dd4bf"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.05"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Dựa trên thói quen, lúc 17:30 bạn thường về nhà:"
                            android:textColor="#80FFFFFF"
                            android:textSize="12sp"
                            android:layout_marginBottom="12dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical"
                                tools:ignore="UseCompoundDrawables">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Cơ quan → Nhà" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Buýt 36 · Khởi hành 17:28" android:textColor="#F97316" android:textSize="12sp" android:layout_marginTop="3dp"/>
                            </LinearLayout>
                            <TextView
                                android:id="@+id/btnAiBook"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mua vé"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                style="@style/Widget.TransGo.Button.Orange"
                                android:backgroundTint="@null"
                                android:paddingStart="18dp"
                                android:paddingEnd="18dp"
                                android:paddingTop="11dp"
                                android:paddingBottom="11dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ═══════════════════════════════════════ -->
                <!-- 5. ĐIỂM THƯỞNG                         -->
                <!-- ═══════════════════════════════════════ -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#0b1928">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical" android:layout_marginBottom="12dp">
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Điểm thưởng TransGo" android:textColor="#60FFFFFF" android:textSize="10sp" android:layout_marginBottom="3dp"/>
                                <TextView android:id="@+id/tvPoints" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:textColor="#F97316" android:textSize="22sp" android:textStyle="bold" android:fontFamily="sans-serif-condensed"/>
                            </LinearLayout>
                            <FrameLayout android:layout_width="46dp" android:layout_height="46dp" android:background="@drawable/bg_icon_circle_orange">
                                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/ic_star"
                                    app:tint="#FFFFFF"/>
                            </FrameLayout>
                        </LinearLayout>

                        <ProgressBar
                            android:id="@+id/progressPoints"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="7dp"
                            android:max="100"
                            android:progress="62"
                            android:progressDrawable="@drawable/bg_timer_progress"
                            android:layout_marginBottom="6dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        android:elevation="12dp"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/bottom_nav_color"
        app:itemTextColor="@color/bottom_nav_color"
        app:itemIconSize="22dp"
        app:labelVisibilityMode="labeled"
        app:itemPaddingTop="8dp"
        app:itemPaddingBottom="6dp"
        app:itemActiveIndicatorStyle="@style/Widget.TransGo.BottomNav.ActiveIndicator"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>