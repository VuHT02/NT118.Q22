<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#0b1928">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="40dp">

        <!-- Background grid -->
        <ImageView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:src="@drawable/bg_grid"
            android:scaleType="fitXY"
            android:alpha="0.4"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Back button -->
        <LinearLayout
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_arrow_back"
                android:layout_marginEnd="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quay lại"
                android:textColor="#80FFFFFF"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Icon circle -->
        <FrameLayout
            android:id="@+id/iconCircle"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_icon_circle_teal"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="28dp"
            app:layout_constraintTop_toBottomOf="@id/btnBack"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_otp" />
        </FrameLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Xác nhận\nOTP"
            android:textColor="#FFFFFF"
            android:textSize="30sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.05"
            android:fontFamily="sans-serif-condensed"
            android:layout_marginStart="24dp"
            android:layout_marginTop="28dp"
            app:layout_constraintTop_toBottomOf="@id/btnBack"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mã đã gửi đến email của bạn"
            android:textColor="#66FFFFFF"
            android:textSize="13sp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- OTP label -->
        <TextView
            android:id="@+id/tvOtpLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NHẬP MÃ OTP"
            android:textColor="#4a6a8a"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:layout_marginStart="24dp"
            android:layout_marginTop="36dp"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- OTP 6 boxes -->
        <LinearLayout
            android:id="@+id/layoutOtp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="14dp"
            app:layout_constraintTop_toBottomOf="@id/tvOtpLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <EditText android:id="@+id/etOtp1"
                style="@style/OtpBoxStyle"
                android:layout_marginEnd="10dp" />

            <EditText android:id="@+id/etOtp2"
                style="@style/OtpBoxStyle"
                android:layout_marginEnd="10dp" />

            <EditText android:id="@+id/etOtp3"
                style="@style/OtpBoxStyle"
                android:layout_marginEnd="10dp" />

            <EditText android:id="@+id/etOtp4"
                style="@style/OtpBoxStyle"
                android:layout_marginEnd="10dp" />

            <EditText android:id="@+id/etOtp5"
                style="@style/OtpBoxStyle"
                android:layout_marginEnd="10dp" />

            <EditText android:id="@+id/etOtp6"
                style="@style/OtpBoxStyle" />

        </LinearLayout>

        <!-- Timer progress bar -->
        <ProgressBar
            android:id="@+id/progressTimer"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="3dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="16dp"
            android:max="60"
            android:progress="60"
            android:progressDrawable="@drawable/bg_timer_progress"
            app:layout_constraintTop_toBottomOf="@id/layoutOtp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Resend row -->
        <LinearLayout
            android:id="@+id/layoutResend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/progressTimer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chưa nhận được mã? "
                android:textColor="#4a6a8a"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvResend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gửi lại (60s)"
                android:textColor="#F97316"
                android:textSize="13sp"
                android:textStyle="bold"
                android:enabled="false"
                android:alpha="0.5" />
        </LinearLayout>

        <!-- Error text -->
        <TextView
            android:id="@+id/tvError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FF5252"
            android:textSize="12sp"
            android:visibility="gone"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/layoutResend"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Confirm button -->
        <Button
            android:id="@+id/btnConfirmOtp"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:text="XÁC NHẬN"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-condensed"
            android:letterSpacing="0.1"
            style="@style/Widget.TransGo.Button.Orange"
            android:backgroundTint="@null"
            android:stateListAnimator="@null"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="36dp"
            app:layout_constraintTop_toBottomOf="@id/tvError"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
