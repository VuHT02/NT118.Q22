<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- ===== BẢN ĐỒ (Google Maps Fragment, chiếm toàn màn hình) ===== -->
    <fragment
        android:id="@+id/mapFragment"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ===== PANEL TÌM KIẾM (nổi trên bản đồ, phía trên) ===== -->
    <LinearLayout
        android:id="@+id/layoutSearchPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_search_panel"
        android:elevation="8dp"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="10dp"
        android:paddingEnd="12dp"
        android:paddingBottom="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Row 1: Điểm đi -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Dot xanh lá -->
            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:background="@drawable/ic_dot_green"
                android:contentDescription="Điểm đi" />

            <!-- Input điểm đi -->
            <EditText
                android:id="@+id/etOrigin"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Chọn điểm xuất phát"
                android:imeOptions="actionNext"
                android:inputType="text"
                android:maxLines="1"
                android:textColor="#212121"
                android:textColorHint="#BDBDBD"
                android:textSize="14sp" />

            <!-- Nút định vị hiện tại -->
            <ImageButton
                android:id="@+id/btnMyLocation"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Vị trí hiện tại"
                android:src="@drawable/ic_my_location"
                android:tint="#43A047" />
        </LinearLayout>

        <!-- Đường kẻ + nút đổi chiều -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Đường thẳng đứng nối 2 dot -->
            <View
                android:layout_width="1dp"
                android:layout_height="20dp"
                android:layout_marginStart="6dp"
                android:background="#BDBDBD" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- Nút đổi chiều (↕) -->
            <ImageButton
                android:id="@+id/btnSwapLocations"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_swap_btn"
                android:contentDescription="Đổi chiều"
                android:elevation="4dp"
                android:src="@drawable/ic_swap_vert"
                android:tint="#43A047" />
        </LinearLayout>

        <!-- Row 2: Điểm đến -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Dot đỏ -->
            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:background="@drawable/ic_dot_red"
                android:contentDescription="Điểm đến" />

            <!-- Input điểm đến -->
            <EditText
                android:id="@+id/etDestination"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Nhập điểm đến"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:maxLines="1"
                android:textColor="#212121"
                android:textColorHint="#BDBDBD"
                android:textSize="14sp" />

            <!-- Nút xóa -->
            <ImageButton
                android:id="@+id/btnClearDest"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Xóa"
                android:src="@drawable/ic_close"
                android:tint="#BDBDBD"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Nút TÌM TUYẾN -->
        <Button
            android:id="@+id/btnSearchRoute"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_btn_green"
            android:text="🔍  Tìm tuyến xe"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- ===== DANH SÁCH GỢI Ý ĐỊA ĐIỂM (hiện khi đang gõ) ===== -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardSuggestions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:elevation="12dp"
        android:visibility="gone"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutSearchPanel"
        tools:visibility="visible">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerSuggestions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="240dp"
            android:nestedScrollingEnabled="false"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:scrollbars="none"
            tools:itemCount="4"
            tools:listitem="@layout/item_place_suggestion" />
    </androidx.cardview.widget.CardView>

    <!-- ===== NÚT ĐIỀU HƯỚNG BẢN ĐỒ (phải màn hình) ===== -->
    <LinearLayout
        android:id="@+id/layoutMapControls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="200dp"
        android:elevation="6dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Nút về nhà / home -->
        <androidx.cardview.widget.CardView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="22dp"
            app:cardElevation="4dp">

            <ImageButton
                android:id="@+id/btnHome"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Về nhà"
                android:src="@drawable/ic_home"
                android:tint="#43A047" />
        </androidx.cardview.widget.CardView>

        <!-- Nút định vị -->
        <androidx.cardview.widget.CardView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="22dp"
            app:cardElevation="4dp">

            <ImageButton
                android:id="@+id/btnLocate"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Vị trí của tôi"
                android:src="@drawable/ic_my_location"
                android:tint="#1E88E5" />
        </androidx.cardview.widget.CardView>

        <!-- Nút la bàn -->
        <androidx.cardview.widget.CardView
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="22dp"
            app:cardElevation="4dp">

            <ImageButton
                android:id="@+id/btnCompass"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="La bàn"
                android:src="@drawable/ic_compass"
                android:tint="#757575" />
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- ===== BOTTOM SHEET: KẾT QUẢ TUYẾN XE GỢI Ý ===== -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/bottomSheetRoutes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_bottom_sheet"
            android:elevation="16dp"
            android:orientation="vertical"
            app:behavior_hideable="true"
            app:behavior_peekHeight="0dp"
            app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

            <!-- Handle kéo -->
            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="6dp"
                android:background="@drawable/bg_handle"
                android:backgroundTint="#BDBDBD" />

            <!-- Tiêu đề bottom sheet -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingTop="6dp"
                android:paddingEnd="16dp"
                android:paddingBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tuyến xe phù hợp"
                    android:textColor="#212121"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvRouteCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_bus_icon_green"
                    android:paddingStart="10dp"
                    android:paddingTop="3dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="3dp"
                    android:text="3 tuyến"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    tools:ignore="HardcodedText" />
            </LinearLayout>

            <!-- Thông tin hành trình tổng -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F1F8E9"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="Khoảng cách"
                    android:src="@drawable/ic_route_length"
                    android:tint="#43A047" />

                <TextView
                    android:id="@+id/tvTotalDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="12.5 km"
                    android:textColor="#2E7D32"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    tools:ignore="HardcodedText" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"
                    android:background="#A5D6A7" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="Thời gian"
                    android:src="@drawable/ic_access_time"
                    android:tint="#43A047" />

                <TextView
                    android:id="@+id/tvTotalTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="~35 phút"
                    android:textColor="#2E7D32"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    tools:ignore="HardcodedText" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="Giá vé"
                    android:src="@drawable/ic_payment"
                    android:tint="#43A047" />

                <TextView
                    android:id="@+id/tvTotalFare"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="7.000đ"
                    android:textColor="#2E7D32"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    tools:ignore="HardcodedText" />
            </LinearLayout>

            <!-- Danh sách tuyến gợi ý -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerSuggestedRoutes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:maxHeight="300dp"
                android:paddingTop="4dp"
                android:paddingBottom="16dp"
                android:scrollbars="none"
                tools:itemCount="3"
                tools:listitem="@layout/item_suggested_route" />

        </LinearLayout>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- Loading overlay -->
    <FrameLayout
        android:id="@+id/layoutLoading"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#44000000"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_search_panel"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <ProgressBar
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:indeterminateTint="#43A047" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Đang tìm tuyến..."
                android:textColor="#424242"
                android:textSize="13sp" />
        </LinearLayout>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
