<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash">

    <!-- ✦ DOT GRID — custom view vẽ lưới chấm toàn màn hình -->
    <ImageView
        android:id="@+id/dotGridView"
        android:src="@drawable/bg_grid"
        android:scaleType="fitXY"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:alpha="1.0" />

    <!-- ✨ RADIAL GLOW — vùng sáng sau logo -->
    <View
        android:id="@+id/viewGlow"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:background="@drawable/bg_glow"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/layoutBrand"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.38" />

    <!-- Logo Circle -->
    <FrameLayout
        android:id="@+id/frameLogoIcon"
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:background="@drawable/bg_logo_circle"
        android:layout_marginBottom="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@id/layoutBrand"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.38">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_transgo_logo"
            android:contentDescription="TransGo Logo" />
    </FrameLayout>

    <!-- TRANSGO Brand -->
    <LinearLayout
        android:id="@+id/layoutBrand"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/frameLogoIcon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvTagline">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TRANS"
            android:textColor="#FFFFFF"
            android:textSize="48sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-condensed"
            android:letterSpacing="0.04"
            android:includeFontPadding="false" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GO"
            android:textColor="#F97316"
            android:textSize="48sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-condensed"
            android:letterSpacing="0.04"
            android:includeFontPadding="false" />
    </LinearLayout>

    <!-- Tagline -->
    <TextView
        android:id="@+id/tvTagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DI CHUYỂN THÔNG MINH"
        android:textColor="#66FFFFFF"
        android:textSize="11sp"
        android:letterSpacing="0.28"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/layoutBrand"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/dotsIndicator" />

    <!-- Dots Indicator -->
    <LinearLayout
        android:id="@+id/dotsIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvTagline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/cityView">

        <View
            android:layout_width="20dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="6dp"
            android:background="@drawable/dot_active" />
        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/dot_inactive"
            android:layout_marginEnd="6dp" />
        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/dot_inactive"
            android:layout_marginEnd="6dp" />
        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/dot_inactive" />
    </LinearLayout>

    <!-- City Skyline -->
    <ImageView
        android:id="@+id/cityView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/img_city_skyline"
        android:scaleType="fitXY"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dotsIndicator"
        app:layout_constraintVertical_bias="1.0"
        app:layout_constraintHeight_percent="0.32" />

    <!-- CTA Button -->

    <!-- Powered By -->
    <TextView
        android:id="@+id/tvPowered"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="POWERED BY TRANSGO PLATFORM"
        android:textColor="#33FFFFFF"
        android:textSize="8sp"
        android:letterSpacing="0.22"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:alpha="1.0" />

</androidx.constraintlayout.widget.ConstraintLayout>