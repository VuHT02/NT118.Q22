<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="80dp"
        android:clipToPadding="false"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== HEADER (compact) ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#0b1928"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Top bar: Back + Title + Badge + Mark all -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <!-- Back button (khớp style bg_header_icon_btn) -->
                        <FrameLayout
                            android:id="@+id/btnBack"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/bg_header_icon_btn"
                            android:layout_marginEnd="10dp">
                            <ImageView
                                android:layout_width="17dp"
                                android:layout_height="17dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_chevron_left"
                                android:tint="#FFFFFF"/>
                        </FrameLayout>

                        <!-- Title + unread badge -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Thông báo"
                                android:textColor="#FFFFFF"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-condensed"/>

                            <!-- Unread count badge (khớp bg_notification_dot style) -->
                            <TextView
                                android:id="@+id/tvUnreadCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:minWidth="20dp"
                                android:gravity="center"
                                android:paddingStart="6dp"
                                android:paddingEnd="6dp"
                                android:paddingTop="2dp"
                                android:paddingBottom="2dp"
                                android:text="3"
                                android:textColor="#FFFFFF"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:background="@drawable/bg_badge_orange"
                                android:visibility="gone"/>
                        </LinearLayout>

                        <!-- Mark all read -->
                        <TextView
                            android:id="@+id/tvMarkAllRead"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đọc tất cả"
                            android:textColor="#F97316"
                            android:textSize="12sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <!-- Tab row (khớp style bg_tab_container từ Home) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_tab_container"
                        android:padding="4dp">

                        <TextView
                            android:id="@+id/tabAll"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="Tất cả"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_tab_selected"/>

                        <TextView
                            android:id="@+id/tabTrip"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="Chuyến đi"
                            android:textColor="#6B7280"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_tab_unselected"/>

                        <TextView
                            android:id="@+id/tabPromo"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="Ưu đãi"
                            android:textColor="#6B7280"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_tab_unselected"/>

                        <TextView
                            android:id="@+id/tabSystem"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="Hệ thống"
                            android:textColor="#6B7280"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_tab_unselected"/>

                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ===== CONTENT ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="14dp">

                <!-- ══════════════════════════════════ -->
                <!-- EMPTY STATE                        -->
                <!-- ══════════════════════════════════ -->
                <LinearLayout
                    android:id="@+id/layoutEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="80dp"
                    android:paddingBottom="80dp"
                    android:visibility="gone">

                    <FrameLayout
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/bg_icon_gray">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_bell"
                            android:alpha="0.4"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Chưa có thông báo nào"
                        android:textColor="#9aa5b4"
                        android:textSize="14sp"/>
                </LinearLayout>

                <!-- ══════════════════════════════════ -->
                <!-- SECTION: HÔM NAY                  -->
                <!-- ══════════════════════════════════ -->
                <TextView
                    android:id="@+id/labelToday"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HÔM NAY"
                    android:textColor="#9aa5b4"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone"/>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardToday"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:id="@+id/listToday"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Notif item 1: Chuyến đi (unread) -->
                        <LinearLayout
                            android:id="@+id/notifItem1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="top"
                            android:padding="14dp"
                            android:background="@drawable/bg_route_item_divider">

                            <!-- Unread dot -->
                            <FrameLayout
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:layout_marginTop="4dp"
                                android:layout_marginEnd="8dp">
                                <View
                                    android:layout_width="8dp"
                                    android:layout_height="8dp"
                                    android:background="@drawable/bg_notification_dot"/>
                            </FrameLayout>

                            <!-- Icon -->
                            <FrameLayout
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:background="@drawable/bg_transport_icon_teal"
                                android:layout_marginEnd="12dp">
                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_waterbus"/>
                            </FrameLayout>

                            <!-- Text -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:layout_marginBottom="3dp">
                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="Chuyến tàu sắp khởi hành"
                                        android:textColor="#0b1928"
                                        android:textSize="13sp"
                                        android:textStyle="bold"/>
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="10 phút"
                                        android:textColor="#9aa5b4"
                                        android:textSize="10sp"/>
                                </LinearLayout>
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Waterbus Bạch Đằng → Thảo Điền lúc 11:00 sẽ khởi hành trong 10 phút. Hãy đến bến đúng giờ!"
                                    android:textColor="#9aa5b4"
                                    android:textSize="12sp"
                                    android:lineSpacingExtra="2dp"/>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Notif item 2: Ưu đãi (unread) -->
                        <LinearLayout
                            android:id="@+id/notifItem2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="top"
                            android:padding="14dp"
                            android:background="@drawable/bg_route_item_divider">

                            <FrameLayout
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:layout_marginTop="4dp"
                                android:layout_marginEnd="8dp">
                                <View
                                    android:layout_width="8dp"
                                    android:layout_height="8dp"
                                    android:background="@drawable/bg_notification_dot"/>
                            </FrameLayout>

                            <FrameLayout
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:background="@drawable/bg_transport_icon_orange"
                                android:layout_marginEnd="12dp">
                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_star"/>
                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:layout_marginBottom="3dp">
                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="Bạn nhận được 30 điểm thưởng"
                                        android:textColor="#0b1928"
                                        android:textSize="13sp"
                                        android:textStyle="bold"/>
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="1 giờ"
                                        android:textColor="#9aa5b4"
                                        android:textSize="10sp"/>
                                </LinearLayout>
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Hoàn thành chuyến đi Bạch Đằng → Thảo Điền. Điểm tích lũy hiện tại: 620 điểm."
                                    android:textColor="#9aa5b4"
                                    android:textSize="12sp"
                                    android:lineSpacingExtra="2dp"/>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Notif item 3: Hệ thống (read) -->
                        <LinearLayout
                            android:id="@+id/notifItem3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="top"
                            android:padding="14dp">

                            <!-- No dot (read) -->
                            <View
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:layout_marginTop="4dp"
                                android:layout_marginEnd="8dp"/>

                            <FrameLayout
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:background="@drawable/bg_transport_icon_blue"
                                android:layout_marginEnd="12dp">
                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_bell"/>
                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:layout_marginBottom="3dp">
                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="Cập nhật lịch tuyến W01"
                                        android:textColor="#0b1928"
                                        android:textSize="13sp"
                                        android:textStyle="bold"/>
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="3 giờ"
                                        android:textColor="#9aa5b4"
                                        android:textSize="10sp"/>
                                </LinearLayout>
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Tuyến Waterbus W01 điều chỉnh giờ chạy từ ngày 22/04/2026. Xem chi tiết lịch mới."
                                    android:textColor="#9aa5b4"
                                    android:textSize="12sp"
                                    android:lineSpacingExtra="2dp"/>
                            </LinearLayout>
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ══════════════════════════════════ -->
                <!-- SECTION: HÔM QUA                  -->
                <!-- ══════════════════════════════════ -->
                <TextView
                    android:id="@+id/labelYesterday"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HÔM QUA"
                    android:textColor="#9aa5b4"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone"/>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardYesterday"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:id="@+id/listYesterday"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Notif item 4 (read) -->
                        <LinearLayout
                            android:id="@+id/notifItem4"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="top"
                            android:padding="14dp"
                            android:background="@drawable/bg_route_item_divider">

                            <View
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:layout_marginTop="4dp"
                                android:layout_marginEnd="8dp"/>

                            <FrameLayout
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:background="@drawable/bg_stat_green"
                                android:layout_marginEnd="12dp">
                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_history"/>
                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:layout_marginBottom="3dp">
                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="Giao dịch thành công"
                                        android:textColor="#0b1928"
                                        android:textSize="13sp"
                                        android:textStyle="bold"/>
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Hôm qua"
                                        android:textColor="#9aa5b4"
                                        android:textSize="10sp"/>
                                </LinearLayout>
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Nạp 50.000đ vào thẻ TransPass thành công. Số dư hiện tại: 85.000đ."
                                    android:textColor="#9aa5b4"
                                    android:textSize="12sp"
                                    android:lineSpacingExtra="2dp"/>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Notif item 5 (read) -->
                        <LinearLayout
                            android:id="@+id/notifItem5"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="top"
                            android:padding="14dp">

                            <View
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:layout_marginTop="4dp"
                                android:layout_marginEnd="8dp"/>

                            <FrameLayout
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:background="@drawable/bg_transport_icon_orange"
                                android:layout_marginEnd="12dp">
                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_star"/>
                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:layout_marginBottom="3dp">
                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="Ưu đãi cuối tuần dành cho bạn"
                                        android:textColor="#0b1928"
                                        android:textSize="13sp"
                                        android:textStyle="bold"/>
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Hôm qua"
                                        android:textColor="#9aa5b4"
                                        android:textSize="10sp"/>
                                </LinearLayout>
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Đi Waterbus T7 &amp; CN giảm 20% — áp dụng đến hết 27/04/2026."
                                    android:textColor="#9aa5b4"
                                    android:textSize="12sp"
                                    android:lineSpacingExtra="2dp"/>
                            </LinearLayout>
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ══════════════════════════════════ -->
                <!-- SECTION: TRƯỚC ĐÓ                 -->
                <!-- ══════════════════════════════════ -->
                <TextView
                    android:id="@+id/labelOlder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TRƯỚC ĐÓ"
                    android:textColor="#9aa5b4"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone"/>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardOlder"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:id="@+id/listOlder"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Notif item 6 (read) -->
                        <LinearLayout
                            android:id="@+id/notifItem6"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="top"
                            android:padding="14dp"
                            android:background="@drawable/bg_route_item_divider">

                            <View
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:layout_marginTop="4dp"
                                android:layout_marginEnd="8dp"/>

                            <FrameLayout
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:background="@drawable/bg_transport_icon_blue"
                                android:layout_marginEnd="12dp">
                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_bell"/>
                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:layout_marginBottom="3dp">
                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="Chào mừng đến TransGo!"
                                        android:textColor="#0b1928"
                                        android:textSize="13sp"
                                        android:textStyle="bold"/>
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="18/04"
                                        android:textColor="#9aa5b4"
                                        android:textSize="10sp"/>
                                </LinearLayout>
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Tài khoản của bạn đã được kích hoạt. Khám phá các tuyến xe buýt, metro và waterbus ngay!"
                                    android:textColor="#9aa5b4"
                                    android:textSize="12sp"
                                    android:lineSpacingExtra="2dp"/>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Notif item 7 (read) -->
                        <LinearLayout
                            android:id="@+id/notifItem7"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="top"
                            android:padding="14dp">

                            <View
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:layout_marginTop="4dp"
                                android:layout_marginEnd="8dp"/>

                            <FrameLayout
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:background="@drawable/bg_stat_green"
                                android:layout_marginEnd="12dp">
                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_history"/>
                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:layout_marginBottom="3dp">
                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="Tóm tắt tuần qua"
                                        android:textColor="#0b1928"
                                        android:textSize="13sp"
                                        android:textStyle="bold"/>
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="14/04"
                                        android:textColor="#9aa5b4"
                                        android:textSize="10sp"/>
                                </LinearLayout>
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Tuần qua bạn đi 12 chuyến, tiết kiệm 1,8 kg CO₂ và tích lũy 180 điểm thưởng."
                                    android:textColor="#9aa5b4"
                                    android:textSize="12sp"
                                    android:lineSpacingExtra="2dp"/>
                            </LinearLayout>
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ===== BOTTOM NAV (khớp Home) ===== -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        android:elevation="12dp"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/bottom_nav_color"
        app:itemTextColor="@color/bottom_nav_color"
        app:itemIconSize="22dp"
        app:labelVisibilityMode="labeled"
        app:itemPaddingTop="8dp"
        app:itemPaddingBottom="6dp"
        app:itemActiveIndicatorStyle="@style/Widget.TransGo.BottomNav.ActiveIndicator"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>