<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#0b1928">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:src="@drawable/bg_grid"
            android:scaleType="fitXY"
            android:alpha="0.4"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Back -->
        <LinearLayout
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                android:src="@drawable/ic_arrow_back" android:layout_marginEnd="6dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Quay lại" android:textColor="#99FFFFFF" android:textSize="13sp" />
        </LinearLayout>

        <!-- Icon teal -->
        <FrameLayout
            android:id="@+id/iconCircle"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_icon_circle_teal"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/btnBack"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView android:layout_width="36dp" android:layout_height="36dp"
                android:layout_gravity="center" android:src="@drawable/ic_otp" />
        </FrameLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Xác nhận OTP"
            android:textColor="#FFFFFF"
            android:textSize="30sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-condensed"
            android:layout_marginStart="24dp"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/btnBack"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvEmailHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mã đã gửi đến email của bạn"
            android:textColor="#66FFFFFF"
            android:textSize="13sp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- OTP label -->
        <TextView
            android:id="@+id/tvOtpLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NHẬP MÃ OTP"
            android:textColor="#4a6a8a"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginStart="24dp"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/tvEmailHint"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- OTP 6 boxes -->
        <LinearLayout
            android:id="@+id/layoutOtp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvOtpLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <EditText android:id="@+id/etOtp1" android:layout_width="44dp" android:layout_height="54dp"
                android:background="@drawable/bg_otp_box" android:gravity="center"
                android:textSize="22sp" android:textStyle="bold" android:textColor="#0b1928"
                android:inputType="number" android:maxLength="1" android:layout_marginEnd="8dp" />

            <EditText android:id="@+id/etOtp2" android:layout_width="44dp" android:layout_height="54dp"
                android:background="@drawable/bg_otp_box" android:gravity="center"
                android:textSize="22sp" android:textStyle="bold" android:textColor="#0b1928"
                android:inputType="number" android:maxLength="1" android:layout_marginEnd="8dp" />

            <EditText android:id="@+id/etOtp3" android:layout_width="44dp" android:layout_height="54dp"
                android:background="@drawable/bg_otp_box" android:gravity="center"
                android:textSize="22sp" android:textStyle="bold" android:textColor="#0b1928"
                android:inputType="number" android:maxLength="1" android:layout_marginEnd="8dp" />

            <EditText android:id="@+id/etOtp4" android:layout_width="44dp" android:layout_height="54dp"
                android:background="@drawable/bg_otp_box_empty" android:gravity="center"
                android:textSize="22sp" android:textStyle="bold" android:textColor="#0b1928"
                android:inputType="number" android:maxLength="1" android:layout_marginEnd="8dp" />

            <EditText android:id="@+id/etOtp5" android:layout_width="44dp" android:layout_height="54dp"
                android:background="@drawable/bg_otp_box_empty" android:gravity="center"
                android:textSize="22sp" android:textStyle="bold" android:textColor="#0b1928"
                android:inputType="number" android:maxLength="1" android:layout_marginEnd="8dp" />

            <EditText android:id="@+id/etOtp6" android:layout_width="44dp" android:layout_height="54dp"
                android:background="@drawable/bg_otp_box_empty" android:gravity="center"
                android:textSize="22sp" android:textStyle="bold" android:textColor="#0b1928"
                android:inputType="number" android:maxLength="1" />
        </LinearLayout>

        <!-- Resend -->
        <LinearLayout
            android:id="@+id/layoutResend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/layoutOtp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Chưa nhận được mã? " android:textColor="#4a6a8a" android:textSize="13sp" />

            <TextView android:id="@+id/tvResend" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Gửi lại (59s)" android:textColor="#F97316" android:textSize="13sp" android:textStyle="bold" />
        </LinearLayout>

        <!-- Confirm button -->
        <Button
            android:id="@+id/btnConfirmOtp"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:text="XÁC NHẬN"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-condensed"
            android:letterSpacing="0.1"
            android:background="@drawable/bg_btn_orange"
            android:backgroundTint="@null"
            android:stateListAnimator="@null"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="40dp"
            app:layout_constraintTop_toBottomOf="@id/layoutResend"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>