<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#0b1928">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:src="@drawable/bg_grid"
            android:scaleType="fitXY"
            android:alpha="0.4"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Back -->
        <LinearLayout
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                android:src="@drawable/ic_arrow_back" android:layout_marginEnd="6dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Quay lại" android:textColor="#99FFFFFF" android:textSize="13sp" />
        </LinearLayout>

        <!-- Shield icon -->
        <FrameLayout
            android:id="@+id/iconCircle"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_icon_circle_orange"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/btnBack"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView android:layout_width="36dp" android:layout_height="36dp"
                android:layout_gravity="center" android:src="@drawable/ic_shield_check" />
        </FrameLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mật khẩu mới"
            android:textColor="#FFFFFF"
            android:textSize="30sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-condensed"
            android:layout_marginStart="24dp"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/btnBack"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tạo mật khẩu mới cho tài khoản"
            android:textColor="#66FFFFFF"
            android:textSize="13sp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- New password label -->
        <TextView
            android:id="@+id/tvNewPassLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MẬT KHẨU MỚI"
            android:textColor="#4a6a8a"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginStart="24dp"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- New password input -->
        <LinearLayout
            android:id="@+id/layoutNewPass"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_input_field"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvNewPassLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView android:layout_width="20dp" android:layout_height="20dp"
                android:src="@drawable/ic_lock" android:layout_marginEnd="12dp" />

            <EditText android:id="@+id/etNewPassword"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:hint="Nhập mật khẩu mới" android:hintTextColor="#9aa5b4"
                android:textColor="#0b1928" android:textSize="14sp"
                android:background="@null" android:inputType="textPassword" android:singleLine="true" />
        </LinearLayout>

        <!-- Confirm password label -->
        <TextView
            android:id="@+id/tvConfirmPassLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="XÁC NHẬN MẬT KHẨU"
            android:textColor="#4a6a8a"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginStart="24dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/layoutNewPass"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Confirm password input -->
        <LinearLayout
            android:id="@+id/layoutConfirmPass"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_input_field"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvConfirmPassLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView android:layout_width="20dp" android:layout_height="20dp"
                android:src="@drawable/ic_lock" android:layout_marginEnd="12dp" />

            <EditText android:id="@+id/etConfirmPassword"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:hint="Nhập lại mật khẩu" android:hintTextColor="#9aa5b4"
                android:textColor="#0b1928" android:textSize="14sp"
                android:background="@null" android:inputType="textPassword" android:singleLine="true" />
        </LinearLayout>

        <!-- Strength label -->
        <TextView
            android:id="@+id/tvStrengthTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Độ mạnh mật khẩu"
            android:textColor="#4a6a8a"
            android:textSize="11sp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="14dp"
            app:layout_constraintTop_toBottomOf="@id/layoutConfirmPass"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Strength bars -->
        <LinearLayout
            android:id="@+id/layoutStrength"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/tvStrengthTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <View android:id="@+id/strengthBar1" android:layout_width="0dp" android:layout_height="4dp"
                android:layout_weight="1" android:background="@drawable/bg_strength_active" android:layout_marginEnd="4dp" />
            <View android:id="@+id/strengthBar2" android:layout_width="0dp" android:layout_height="4dp"
                android:layout_weight="1" android:background="@drawable/bg_strength_active" android:layout_marginEnd="4dp" />
            <View android:id="@+id/strengthBar3" android:layout_width="0dp" android:layout_height="4dp"
                android:layout_weight="1" android:background="@drawable/bg_strength_inactive" android:layout_marginEnd="4dp" />
            <View android:id="@+id/strengthBar4" android:layout_width="0dp" android:layout_height="4dp"
                android:layout_weight="1" android:background="@drawable/bg_strength_inactive" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvStrengthLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Trung bình"
            android:textColor="#F97316"
            android:textSize="11sp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/layoutStrength"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Reset button -->
        <Button
            android:id="@+id/btnResetPassword"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:text="ĐẶT LẠI MẬT KHẨU"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-condensed"
            android:letterSpacing="0.1"
            android:background="@drawable/bg_btn_orange"
            android:backgroundTint="@null"
            android:stateListAnimator="@null"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="40dp"
            app:layout_constraintTop_toBottomOf="@id/tvStrengthLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>