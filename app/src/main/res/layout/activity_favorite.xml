<?xml version="1.0" encoding="utf-8"?>
<!--
  TransGo — Màn hình "Địa điểm yêu thích"
  Root layout: CoordinatorLayout để hỗ trợ AppBar collapsing + FAB
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    tools:context=".YeuThichActivity">

    <!-- ══════════════════════════════════════
         APP BAR (Header sticky)
    ══════════════════════════════════════ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/header_bg"
        app:elevation="4dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <!-- Header top row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:baselineAligned="false">

                <!-- Icon ❤️ -->
                <androidx.cardview.widget.CardView
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/orange_dim"
                    app:cardElevation="0dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="❤️"
                        android:textSize="20sp"
                        android:gravity="center"/>
                </androidx.cardview.widget.CardView>

                <!-- Title + subtitle -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="12dp">

                    <TextView
                        android:id="@+id/tvTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Địa điểm yêu thích"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:letterSpacing="-0.01"/>

                    <TextView
                        android:id="@+id/tvSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Khám phá Sài Gòn bằng PTCC"
                        android:textColor="@color/white_55"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <!-- Bell icon button -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/btnNotification"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    app:cardCornerRadius="10dp"
                    app:cardBackgroundColor="@color/white_10"
                    app:cardElevation="0dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="🔔"
                        android:textSize="14sp"
                        android:gravity="center"/>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </androidx.appcompat.widget.Toolbar>

        <!-- Chip filter bar -->
        <HorizontalScrollView
            android:id="@+id/chipScrollView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="14dp">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:chipSpacingHorizontal="8dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAll"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:text="Tất cả"
                    android:textSize="12.5sp"
                    android:textStyle="bold"
                    android:checked="true"
                    app:chipBackgroundColor="@color/orange"
                    app:checkedIconVisible="false"
                    style="@style/Widget.Material3.Chip.Filter"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipMetro"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:text="🚇 Metro"
                    android:textSize="12.5sp"
                    android:textStyle="bold"
                    app:chipBackgroundColor="@color/white_12"
                    app:checkedIconVisible="false"
                    style="@style/Widget.Material3.Chip.Filter"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipBus"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:text="🚌 Xe buýt"
                    android:textSize="12.5sp"
                    android:textStyle="bold"
                    app:chipBackgroundColor="@color/white_12"
                    app:checkedIconVisible="false"
                    style="@style/Widget.Material3.Chip.Filter"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipWaterbus"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:text="⛵ Waterbus"
                    android:textSize="12.5sp"
                    android:textStyle="bold"
                    app:chipBackgroundColor="@color/white_12"
                    app:checkedIconVisible="false"
                    style="@style/Widget.Material3.Chip.Filter"/>

            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <!-- Thin divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/white_10"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"/>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ══════════════════════════════════════
         SCROLLABLE BODY
    ══════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="100dp"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Search bar ── -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="4dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSearch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="14dp"
                    app:cardBackgroundColor="@color/surface"
                    app:cardElevation="1dp"
                    app:strokeColor="@color/border"
                    app:strokeWidth="1.5dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:baselineAligned="false">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔍"
                            android:textSize="15sp"/>

                        <EditText
                            android:id="@+id/etSearch"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"
                            android:hint="Tìm địa điểm yêu thích..."
                            android:textColorHint="@color/txt3"
                            android:textColor="@color/txt1"
                            android:textSize="13.5sp"
                            android:background="@null"
                            android:inputType="text"
                            android:imeOptions="actionSearch"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>

            <!-- ── Section: Hot spots ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🔥 Địa điểm hot"
                    android:textColor="@color/txt1"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvHotSeeAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xem tất cả →"
                    android:textColor="@color/orange"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Hot spots horizontal list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvHotSpots"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="4dp"
                android:clipToPadding="false"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@drawable/item_hotspot"/>

            <!-- ── Section: Route suggestions ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🗺️ Gợi ý lộ trình tối ưu"
                    android:textColor="@color/txt1"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvRouteSeeAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xem tất cả →"
                    android:textColor="@color/orange"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Route cards (vertical, no RecyclerView needed) -->
            <LinearLayout
                android:id="@+id/llRouteCards"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <!-- Route card 1: Nhanh nhất -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardRoute1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardCornerRadius="18dp"
                    app:cardBackgroundColor="@color/surface"
                    app:cardElevation="1dp"
                    app:strokeColor="@color/border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Top row: tag + time/price -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="⚡ Nhanh nhất"
                                android:textColor="@color/green"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:background="@drawable/bg_tag_green"
                                android:paddingStart="9dp"
                                android:paddingEnd="9dp"
                                android:paddingTop="3dp"
                                android:paddingBottom="3dp"/>

                            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="23 phút"
                                android:textColor="@color/txt1"
                                android:textSize="14sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="· 6.000đ"
                                android:textColor="@color/txt2"
                                android:textSize="12sp"
                                android:layout_marginStart="6dp"/>
                        </LinearLayout>

                        <!-- Destination -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Nhà thờ Đức Bà"
                            android:textColor="@color/txt1"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp"/>

                        <!-- Transport badges + buy button -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🚇 M1"
                                android:textColor="@color/metro_txt"
                                android:textSize="11.5sp"
                                android:textStyle="bold"
                                android:background="@drawable/bg_badge_metro"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:paddingTop="5dp"
                                android:paddingBottom="5dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="→"
                                android:textColor="@color/txt3"
                                android:textSize="11sp"
                                android:layout_marginStart="6dp"
                                android:layout_marginEnd="6dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🚌 Tuyến 36"
                                android:textColor="@color/bus_txt"
                                android:textSize="11.5sp"
                                android:textStyle="bold"
                                android:background="@drawable/bg_transport_bus"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:paddingTop="5dp"
                                android:paddingBottom="5dp"/>

                            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

                            <Button
                                android:id="@+id/btnBuyRoute1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mua vé"
                                android:textColor="@color/white"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:backgroundTint="@color/orange"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:paddingTop="7dp"
                                android:paddingBottom="7dp"
                                style="@style/Widget.Material3.Button"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Route card 2: Rẻ nhất -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardRoute2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardCornerRadius="18dp"
                    app:cardBackgroundColor="@color/surface"
                    app:cardElevation="1dp"
                    app:strokeColor="@color/border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Top row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="💰 Rẻ nhất"
                                android:textColor="@color/orange"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:background="@drawable/bg_circle_orange"
                                android:paddingStart="9dp"
                                android:paddingEnd="9dp"
                                android:paddingTop="3dp"
                                android:paddingBottom="3dp"/>

                            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="41 phút"
                                android:textColor="@color/txt1"
                                android:textSize="14sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="· 3.000đ"
                                android:textColor="@color/txt2"
                                android:textSize="12sp"
                                android:layout_marginStart="6dp"/>
                        </LinearLayout>

                        <!-- Destination -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Bến Bạch Đằng"
                            android:textColor="@color/txt1"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp"/>

                        <!-- Transport badges + buy button -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🚌 Tuyến 04"
                                android:textColor="@color/bus_txt"
                                android:textSize="11.5sp"
                                android:textStyle="bold"
                                android:background="@drawable/bg_transport_bus"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:paddingTop="5dp"
                                android:paddingBottom="5dp"/>

                            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

                            <Button
                                android:id="@+id/btnBuyRoute2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mua vé"
                                android:textColor="@color/white"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:backgroundTint="@color/orange"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:paddingTop="7dp"
                                android:paddingBottom="7dp"
                                style="@style/Widget.Material3.Button"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ── Section: Tất cả địa điểm ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📍 Tất cả địa điểm"
                    android:textColor="@color/txt1"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvSortBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⇅ Sắp xếp"
                    android:textColor="@color/txt2"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_sort_btn"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"/>
            </LinearLayout>

            <!-- Places list (RecyclerView) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPlaces"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_place_row"
                tools:itemCount="5"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ══════════════════════════════════════
         FAB — "Tìm từ vị trí của tôi"
    ══════════════════════════════════════ -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabFindLocation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="24dp"
        android:text="📍 Tìm từ vị trí của tôi"
        android:textColor="@color/white"
        android:textSize="13.5sp"
        android:textStyle="bold"
        app:backgroundTint="@color/orange"
        app:elevation="8dp"
        app:fabSize="normal"
        app:layout_behavior="com.google.android.material.behavior.HideBottomViewOnScrollBehavior"/>

    <!-- ══════════════════════════════════════
         BOTTOM NAV
    ══════════════════════════════════════ -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/surface"
        app:itemTextColor="@color/bottom_nav_color"
        app:itemIconTint="@color/bottom_nav_color"
        app:selectedItemId="@id/nav_favorite"
        app:menu="@menu/bottom_nav_menu"
        app:elevation="8dp"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>