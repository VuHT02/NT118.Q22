<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F1923">

    <!-- ===== HERO: ảnh bến tàu full width ===== -->
    <FrameLayout
        android:id="@+id/layoutHero"
        android:layout_width="0dp"
        android:layout_height="220dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Ảnh nền bến tàu -->
        <ImageView
            android:id="@+id/ivHeroBg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="Bến tàu"
            android:scaleType="centerCrop"
            android:src="@drawable/img_waterbus_hero" />

        <!-- Gradient tối phía dưới ảnh -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_hero_scrim" />

        <!-- Nút back -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_back_btn_white"
            android:contentDescription="Quay lại"
            android:src="@drawable/ic_arrow_back_white"
            android:tint="#1A1A2E" />

        <!-- Route title: Điểm đi → Điểm đến -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvOriginName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="130dp"
                android:text="Bến tàu Bạch Đằng"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:text="→"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDestName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="130dp"
                android:text="Bến tàu Thảo Điền"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />
        </LinearLayout>
    </FrameLayout>

    <!-- ===== DATE PICKER BAR (vàng cam) ===== -->
    <LinearLayout
        android:id="@+id/layoutDateBar"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:background="@drawable/bg_date_bar"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutHero">

        <!-- Nút lịch -->
        <ImageButton
            android:id="@+id/btnCalendar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Chọn ngày"
            android:src="@drawable/ic_calendar"
            android:tint="#1A1A2E" />

        <!-- Nút prev ngày -->
        <ImageButton
            android:id="@+id/btnPrevDay"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Ngày trước"
            android:src="@drawable/ic_chevron_left"
            android:tint="#1A1A2E" />

        <!-- Ngày đang xem -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Khởi hành"
                android:textColor="#1A1A2E"
                android:textSize="11sp"
                android:alpha="0.7" />

            <TextView
                android:id="@+id/tvSelectedDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thứ 2, 20/04/2026"
                android:textColor="#1A1A2E"
                android:textSize="15sp"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />
        </LinearLayout>

        <!-- Nút next ngày -->
        <ImageButton
            android:id="@+id/btnNextDay"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Ngày sau"
            android:src="@drawable/ic_chevron_right"
            android:tint="#1A1A2E" />

        <!-- Nút filter -->
        <ImageButton
            android:id="@+id/btnFilter"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Lọc chuyến"
            android:src="@drawable/ic_filter"
            android:tint="#1A1A2E" />
    </LinearLayout>

    <!-- ===== BODY: timeline + danh sách chuyến ===== -->
    <LinearLayout
        android:id="@+id/layoutBody"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#0F1923"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutDateBar">

        <!-- Cột timeline giờ (trái) -->
        <LinearLayout
            android:id="@+id/layoutTimeline"
            android:layout_width="48dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingTop="16dp">

            <!-- Thanh xanh dọc + giờ -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerTimeline"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:nestedScrollingEnabled="false"
                android:scrollbars="none"
                tools:itemCount="8"
                tools:listitem="@layout/item_timeline_hour" />
        </LinearLayout>

        <!-- Danh sách chuyến (phải) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerSchedule"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingTop="12dp"
            android:paddingEnd="14dp"
            android:paddingBottom="24dp"
            android:scrollbars="none"
            tools:itemCount="3"
            tools:listitem="@layout/item_waterbus_trip" />
    </LinearLayout>

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyle"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:indeterminateTint="#F5A623"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutDateBar" />

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/layoutEmpty"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutDateBar">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚢"
            android:textSize="48sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Không có chuyến nào"
            android:textColor="#546E7A"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Vui lòng chọn ngày khác"
            android:textColor="#37474F"
            android:textSize="13sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>