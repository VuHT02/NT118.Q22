<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.CityMove" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#0b1928</item>
        <item name="colorPrimaryVariant">#0d1e35</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#F97316</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="buttonStyle">@style/Widget.TransGo.Button</item>
        <item name="materialButtonStyle">@style/Widget.TransGo.Button</item>
        <item name="android:buttonStyle">@style/Widget.TransGo.Button</item>
    </style>

    <style name="Widget.TransGo.Button" parent="Widget.MaterialComponents.Button">
