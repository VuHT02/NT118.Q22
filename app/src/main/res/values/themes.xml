<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ════ Base theme ════ -->
    <style name="Theme.TransGo" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/blue_primary</item>
        <item name="colorPrimaryVariant">@color/blue_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/orange_accent</item>
        <item name="android:windowBackground">@color/bg_page</item>
        <item name="android:statusBarColor">@color/bg_page</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/bg_page</item>
        <item name="android:fontFamily">@font/nunito</item>
        <item name="fontFamily">@font/nunito</item>
        <!-- ✅ Chỉ định style mặc định cho Button -->
        <item name="materialButtonStyle">@style/Widget.TransGo.Button.Orange</item>
        <item name="android:buttonStyle">@style/Widget.TransGo.Button.Orange</item>
    </style>

    <!-- ════ Buttons (Đã gộp) ════ -->
    <!-- Style gốc chứa tất cả thuộc tính chung -->
    <style name="Widget.TransGo.Button.Base" parent="Widget.MaterialComponents.Button">
        <item name="android:fontFamily">@font/nunito</item>
        <item name="fontFamily">@font/nunito</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:background">@drawable/bg_button_base</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="Widget.TransGo.Button.Orange" parent="Widget.TransGo.Button.Base">
        <item name="backgroundTint">@color/orange_accent</item>
    </style>

    <style name="Widget.TransGo.Button.Social" parent="Widget.TransGo.Button.Base">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="backgroundTint">@color/white</item>
        <item name="android:minHeight">48dp</item>
        <item name="strokeColor">@color/border_default</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- ════ EditText ════ -->
    <style name="Widget.TransGo.EditText" parent="Widget.AppCompat.EditText">
        <item name="android:fontFamily">@font/nunito</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_disabled</item>
        <item name="android:background">@drawable/bg_input_field</item>
        <item name="android:paddingTop">13dp</item>
        <item name="android:paddingBottom">13dp</item>
        <item name="android:paddingStart">44dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="fontFamily">@font/nunito</item>
    </style>

    <!-- ════ CheckBox ════ -->

    <!-- ════ Text Appearances ════ -->

    <style name="Widget.TransGo.BottomNav.ActiveIndicator" parent="">
        <item name="android:color">#1AF97316</item>
        <item name="shapeAppearance">@style/ShapeAppearance.TransGo.Rounded</item>
    </style>

    <style name="ShapeAppearance.TransGo.Rounded" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="OtpBoxStyle">
        <item name="android:layout_width">46dp</item>
        <item name="android:layout_height">58dp</item>
        <item name="android:background">@drawable/bg_otp_box_empty</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#0b1928</item>
        <item name="android:inputType">number</item>
        <item name="android:maxLength">1</item>
        <item name="android:cursorVisible">false</item>
        <item name="android:importantForAutofill">no</item>
    </style>

</resources>
